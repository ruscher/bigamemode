{
  "app-id": "com.biglinux.BiGameMode",
  "runtime": "org.gnome.Platform",
  "runtime-version": "47",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "bigame-ui",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--talk-name=com.feralinteractive.GameMode",
    "--system-talk-name=net.hadess.PowerProfiles",
    "--system-talk-name=org.freedesktop.PolicyKit1",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--filesystem=/sys/devices/system/cpu:ro",
    "--filesystem=/sys/class/drm:ro",
    "--filesystem=/sys/class/hwmon:ro",
    "--filesystem=/tmp/falcond_status:ro"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/bigame-mode/cargo"
    }
  },
  "modules": [
    {
      "name": "bigame-mode",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release -p bigame-ui",
        "install -Dm755 target/release/bigame-ui /app/bin/bigame-ui",
        "install -Dm644 data/com.biglinux.BiGameMode.desktop /app/share/applications/com.biglinux.BiGameMode.desktop",
        "install -Dm644 data/com.biglinux.BiGameMode.metainfo.xml /app/share/metainfo/com.biglinux.BiGameMode.metainfo.xml",
        "install -Dm644 data/icons/com.biglinux.BiGameMode.svg /app/share/icons/hicolor/scalable/apps/com.biglinux.BiGameMode.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
