# /etc/sudoers.d/bigame-mode
# Generated by bigame-mode PKGBUILD — do not edit manually.
#
# Allows members of the wheel group to write falcond configuration, game
# profiles, and AMD VCache sysfs settings without a password prompt.
# Scope: local, active session only (wheel group).
#
# Commands granted:
#   - Create falcond config/profile directories
#   - Write falcond global config
#   - Write/delete per-game profiles
#   - Write AMD 3D V-Cache sysfs mode
#   - Send SIGHUP to falcond for live config reload

Cmnd_Alias BIGAME_DIRS = \
    /usr/bin/mkdir -p /etc/falcond, \
    /usr/bin/mkdir -p /usr/share/falcond, \
    /usr/bin/mkdir -p /usr/share/falcond/profiles, \
    /usr/bin/mkdir -p /usr/share/falcond/profiles/user

Cmnd_Alias BIGAME_WRITE = \
    /usr/bin/tee /etc/falcond/config.conf, \
    /usr/bin/tee /usr/share/falcond/profiles/user/*

Cmnd_Alias BIGAME_DELETE = \
    /usr/bin/rm /usr/share/falcond/profiles/user/*

Cmnd_Alias BIGAME_SYSFS = \
    /usr/bin/tee /sys/bus/platform/drivers/amd_x3d_vcache/*/amd_x3d_mode

Cmnd_Alias BIGAME_DAEMON = \
    /usr/bin/systemctl enable --now falcond, \
    /usr/bin/pkill -HUP falcond

%wheel ALL=(root) NOPASSWD: BIGAME_DIRS, BIGAME_WRITE, BIGAME_DELETE, BIGAME_SYSFS, BIGAME_DAEMON
