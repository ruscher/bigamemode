#: crates/bigame-ui/src/widgets/tutorial.rs:34
#: crates/bigame-ui/src/window.rs:44 crates/bigame-ui/src/window.rs:62
msgid "Dashboard"
msgstr "Painel"

#: crates/bigame-ui/src/widgets/tutorial.rs:36
msgid "<b>Stat Bar</b> — CPU frequency, GPU temperature and RAM at a glance."
msgstr "<b>Barra de Estatísticas</b> — Frequência de CPU, temperatura da GPU e RAM de uma vez."

#: crates/bigame-ui/src/widgets/tutorial.rs:37
msgid ""
"<b>Performance Booster</b> — Enable or disable falcond for gaming "
"optimisations."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:38
msgid ""
"<b>Frame Generation (lsfg-vk)</b> — Shows whether the Vulkan implicit layer "
"is installed. No Steam launch options are needed — it activates "
"automatically for configured games."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:39
msgid ""
"<b>Power Profile</b> — Current system power profile (Balanced / "
"Performance / Power Saver)."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:40
msgid ""
"<b>Falcond Daemon</b> — Shows the active SCX scheduler, VCache mode and "
"current game profile."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:41
msgid ""
"<b>System Telemetry</b> — Live sparkline graphs: CPU/GPU frequency, GPU "
"temperature, disk I/O, network latency and RAM usage."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:42
msgid ""
"<b>Detected Games</b> — Games found via Steam, Lutris and Heroic. Create a "
"performance profile or launch directly with Gamescope."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:50
msgid ""
"<b>Profile Wizard</b> — Guided setup with presets optimised for competitive "
"FPS, strategy, simulation and more."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:51
msgid ""
"<b>Per-game Profiles</b> — Override global Tuning settings for a specific "
"game executable."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:52
msgid ""
"<b>Auto-Apply</b> — Falcond detects the game process at launch and applies "
"the matching profile automatically."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:53
msgid ""
"<b>New Profile (+)</b> — Create a blank profile and customise every "
"parameter manually."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:54
msgid ""
"<b>Import</b> — Load a .conf or .toml profile from disk. Drag-and-drop onto "
"the list also works."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:60
#: crates/bigame-ui/src/window.rs:64
msgid "Tuning"
msgstr "Ajustes"

#: crates/bigame-ui/src/widgets/tutorial.rs:62
msgid ""
"<b>Falcond Daemon</b> — Start or stop the daemon and toggle auto-start on "
"login."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:63
msgid ""
"<b>SCX Scheduler</b> — sched-ext BPF CPU scheduler:\n"
"  · bpfland — Low latency, ideal for competitive games\n"
"  · lavd — Load-aware, good for mixed workloads\n"
"  · rusty — General-purpose, stable default\n"
"  · flash — Maximum throughput"
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:64
msgid ""
"<b>CPU Governor</b> — Performance keeps frequency at maximum; Powersave "
"scales down to save energy."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:65
msgid ""
"<b>VCache Mode</b> — AMD Ryzen X3D only. Game Mode routes workloads to the "
"VCache chiplet for lower memory latency."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:66
msgid ""
"<b>Frame Generation</b> — lsfg-vk Vulkan layer: inserts interpolated frames "
"to boost perceived FPS."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:67
msgid ""
"<b>Device Mode</b> — Optimise kernel tuning for Gaming or Desktop workloads."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:75
msgid ""
"<b>Resolution</b> — Set the game render resolution independently from your "
"desktop resolution."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:76
msgid "<b>Framerate Limit</b> — Hard cap on FPS for consistent frame pacing."
msgstr "<b>Limite de FPS</b> — Limite máximo de FPS para cadência de quadros consistente."

#: crates/bigame-ui/src/widgets/tutorial.rs:77
msgid ""
"<b>FSR</b> — FidelityFX Super Resolution upscaling. Sharpness: 0 = blurry · "
"20 = sharpest."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:78
msgid ""
"<b>MangoHud</b> — Enable the MangoHud performance overlay inside the "
"Gamescope window."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:79
msgid ""
"<b>Command</b> — Game or program to launch inside Gamescope (e.g. <tt>steam "
"-gamepadui</tt>)."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:80
msgid ""
"<b>Launch</b> — Applies current settings and starts the Gamescope compositor."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:86
#: crates/bigame-ui/src/window.rs:66
msgid "Logs"
msgstr "Registros"

#: crates/bigame-ui/src/widgets/tutorial.rs:88
msgid ""
"<b>Falcond Status</b> — Live read of <tt>/tmp/falcond_status</tt>: current "
"scheduler, governor and active profile."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:89
msgid ""
"<b>Gaming Services Journal</b> — journald entries from falcond and related "
"gaming services."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:90
msgid ""
"<b>Kernel &amp; GPU Messages</b> — dmesg output filtered for GPU and gaming-"
"related entries."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:91
msgid ""
"<b>Application Log</b> — BiGame-mode internal events: profile loads, D-Bus "
"calls and errors."
msgstr ""

#: crates/bigame-ui/src/widgets/tutorial.rs:92
msgid ""
"<b>Auto-Refresh</b> — Logs update every 5 seconds. Click ↺ to force an "
"immediate refresh."
msgstr ""

